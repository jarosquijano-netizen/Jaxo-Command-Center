# ============================================
# FAMILY COMMAND CENTER - ENVIRONMENT VARIABLES
# ============================================

# Base de Datos
DATABASE_URL=postgresql://user:password@localhost:5432/family_command_center

# API Keys
ANTHROPIC_API_KEY=sk-ant-api03-your-api-key-here
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Flask Configuration
SECRET_KEY=your-secret-key-here-use-secrets-token-hex-32
FLASK_ENV=development
FLASK_DEBUG=True

# Server
PORT=5000
HOST=0.0.0.0

# CORS (separar múltiples con comas)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:5500

# Timezone
TIMEZONE=Europe/Madrid

# Logging
LOG_LEVEL=INFO

# ============================================
# NOTAS:
# 1. Copiar este archivo a .env
# 2. Reemplazar valores de ejemplo con reales
# 3. NUNCA commitear .env con credenciales reales
# ============================================
